{ "compilerOptions": 
  { 
    "esModuleInterop": true, 
    "allowSyntheticDefaultImports": true, 
    "resolveJsonModule": true, 
    "typeRoots": ["./node_modules/@types"], 
    "baseUrl": "./", 
    "paths": { 
      "*": ["node_modules/*"] }
    },
    "sourceMap": true,
    "outDir": "./dist",
    "target": "ES6",
    "module": "CommonJS"
}